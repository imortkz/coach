# .env.example — Copy to .env and fill in values before running docker-compose.prod.yml
# Never commit .env to version control.

# ─── Required for production ────────────────────────────────────────────────

# Stable secret key for signing JWT tokens. Must NOT change between restarts
# (changing it invalidates all user sessions).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Telegram Bot Token from @BotFather (used for HMAC-SHA-256 auth verification).
# Create a bot at https://t.me/BotFather and run /newbot.
TELEGRAM_BOT_TOKEN=

# Telegram bot username WITHOUT the @ prefix (used by the frontend widget).
# This is the public bot username, e.g. for @MyGymCoachBot enter: MyGymCoachBot
VITE_TELEGRAM_BOT_NAME=

# Production domain (DNS A-record must point at the VPS public IP).
# Used by nginx (server_name + cert paths) and by certbot (cert subject).
# Example: coach.imort.kz
DOMAIN=

# Email used by certbot for Let's Encrypt account + renewal warnings.
# ACME requires it; LE sends notices here if a renewal fails.
ACME_EMAIL=

# ─── Optional overrides ──────────────────────────────────────────────────────

# Automated-agent API access. A static opaque key that authenticates an agent
# (e.g. a personal assistant / cron) as the user whose telegram_id matches
# AGENT_USER_TELEGRAM_ID, with full read+write on that user's data — same scope
# as that user's own session. Independent of JWT_SECRET: clear AGENT_API_TOKEN
# to revoke instantly without affecting any login session. Leave empty to disable.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# AGENT_API_TOKEN=
# AGENT_USER_TELEGRAM_ID=0

# MongoDB database name (default: gymcoach)
# MONGODB_DB_NAME=gymcoach

# Set to "true" only for local development (bypasses Telegram auth).
# MUST be "false" in production.
# DEV_MODE=false

# ─── Backup retention (M006) ─────────────────────────────────────────────────

# Hours of hourly backups to retain. Beyond this age, hourly archives in
# /var/backups/gymcoach/hourly/ are pruned automatically.
# BACKUP_HOURLY_KEEP=48

# Days of daily backups to retain. The daily directory holds one archive
# per day (the midnight-UTC hourly backup, copied over). Beyond this age,
# daily archives in /var/backups/gymcoach/daily/ are pruned automatically.
# BACKUP_DAILY_KEEP=30
