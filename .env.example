# .env.example — Copy to .env and fill in values before running docker-compose.prod.yml
# Never commit .env to version control.

# ─── Required for production ────────────────────────────────────────────────

# Stable secret key for signing JWT tokens. Must NOT change between restarts
# (changing it invalidates all user sessions).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Telegram Bot Token from @BotFather (used for HMAC-SHA-256 auth verification).
# Create a bot at https://t.me/BotFather and run /newbot.
TELEGRAM_BOT_TOKEN=

# Telegram bot username WITHOUT the @ prefix (used by the frontend widget).
# This is the public bot username, e.g. for @MyGymCoachBot enter: MyGymCoachBot
VITE_TELEGRAM_BOT_NAME=

# Production domain (DNS A-record must point at the VPS public IP).
# Used by nginx (server_name + cert paths) and by certbot (cert subject).
# Example: coach.imort.kz
DOMAIN=

# Email used by certbot for Let's Encrypt account + renewal warnings.
# ACME requires it; LE sends notices here if a renewal fails.
ACME_EMAIL=

# ─── Optional overrides ──────────────────────────────────────────────────────

# MongoDB database name (default: gymcoach)
# MONGODB_DB_NAME=gymcoach

# Set to "true" only for local development (bypasses Telegram auth).
# MUST be "false" in production.
# DEV_MODE=false
